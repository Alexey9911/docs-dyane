{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Ghost Link",
  "colors": {
    "primary": "#9CA3AF",
    "light": "#6B7280",
    "dark": "#1A1A1A"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Try Ghost",
          "icon": "ghost",
          "href": "https://ghostlinkfinance.com"
        },
        {
          "anchor": "Twitter",
          "icon": "x-twitter",
          "href": "https://x.com/GhostLinkFi"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Whitepaper",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "protocol"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/send",
              "features/Distribute",
              "features/sweep"
            ]
          },
          {
            "group": "Token",
            "pages": [
              "token/overview",
              "token/tokenomics"
            ]
          },
          {
            "group": "About",
            "pages": [
              "about/faq",
              "about/roadmap",
              "about/links"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logoDark.svg",
    "dark": "/logoWhite.svg",
    "height": 120
  },
  "navbar": {
    "links": [
      {
        "label": "Telegram",
        "href": "https://t.me/GhostLinkFinance"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Try Ghost",
      "href": "https://ghostlinkfinance.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/GhostLinkFi",
      "telegram": "https://t.me/GhostLinkFinance",
      "website": "https://ghostlinkfinance.com"
    }
  },
  "seo": {
    "indexHiddenPages": false
  },
  "appearance": {
    "default": "dark"
  }
}
